# Public
NEXT_PUBLIC_BASE_URL=https://k-lol-gg.vercel.app

# Database
DATABASE_URL=

# Auth
JWT_SECRET=
AUTH_TOKEN_MAX_AGE=7d
ADMIN_TOKEN_VALUE=
ALLOW_LEGACY_ADMIN_TOKEN=false
SECURITY_ALLOWED_ORIGINS=https://k-lol-gg.vercel.app

# Discord OAuth / Bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BOT_API_SECRET=
DISCORD_AUTO_FINISH_HOLD_MINUTES=10

# Kakao Bot/API
KAKAO_RECRUIT_SECRET=
KAKAO_SEARCH_LAYER_SECRET=
KAKAO_OPENCHAT_SECRET=

# Riot
# Production 승인 전에는 false 유지. true로 바꾸면 서버 Route Handler에서만 Riot API 호출이 허용됩니다.
RIOT_FEATURE_ENABLED=false
RIOT_API_KEY=
RIOT_REGION=asia
RIOT_PLATFORM=kr
RIOT_MATCH_FETCH_LIMIT=20
RIOT_USER_SYNC_COOLDOWN_MINUTES=60
RIOT_ADMIN_SYNC_COOLDOWN_MINUTES=10
RIOT_ADMIN_FULL_SYNC_COOLDOWN_MINUTES=1440
RIOT_LOG_RETENTION_DAYS=90

# Security Phase 4
# Production에서는 false 권장. true면 Discord/Kakao secret을 query string에서도 임시 허용합니다.
SECURITY_ALLOW_QUERY_SECRET=false
# Kakao 서버 API까지 secret 검증을 강제하려면 true로 설정합니다.
SECURITY_REQUIRE_KAKAO_SECRET=false

# HMAC signature enforcement. Keep false during compatibility rollout, set true after bot/Kakao callers are updated.
SECURITY_REQUIRE_HMAC=false
# Riot Sign On / OAuth ownership verification
RIOT_RSO_ENABLED=false
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=
RIOT_RSO_STATE_TTL_MINUTES=10
