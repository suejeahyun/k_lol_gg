# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Auth
JWT_SECRET="replace-with-long-random-secret"
ADMIN_TOKEN_VALUE="replace-with-long-random-admin-token"
ALLOW_LEGACY_ADMIN_TOKEN="false"
SUPER_ADMIN_ID="admin"
SUPER_ADMIN_PASSWORD="replace-with-initial-admin-password"

# Kakao bot
KAKAO_OPENCHAT_SECRET="replace-with-kakao-openchat-secret"
KAKAO_SEARCH_PLAYER_SECRET="replace-with-kakao-search-player-secret"
KAKAO_RECRUIT_SECRET="replace-with-kakao-recruit-secret"

# Riot / AI
RIOT_API_KEY="RGAPI-..."
OPENAI_API_KEY="sk-..."
OPENAI_VISION_MODEL="gpt-4.1-mini"

# App
NEXT_PUBLIC_BASE_URL="https://k-lol-gg.vercel.app"

# Discord OAuth / Bot integration
NEXT_PUBLIC_BASE_URL="https://k-lol-gg.vercel.app"
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="https://k-lol-gg.vercel.app/api/auth/discord/callback"
DISCORD_BOT_TOKEN=""
DISCORD_BOT_API_SECRET=""
DISCORD_AUTO_FINISH_HOLD_MINUTES="10"

# Discord 운영 자동화 / 봇 서버
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_PUBLIC_KEY=""
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
DISCORD_BOT_API_SECRET=""
NEXT_PUBLIC_BASE_URL="https://k-lol-gg.vercel.app"

# discord-bot-sample/.env 전용
KLOL_BASE_URL="https://k-lol-gg.vercel.app"
