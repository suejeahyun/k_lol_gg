# Public
NEXT_PUBLIC_BASE_URL=https://k-lol-gg.vercel.app

# Database
DATABASE_URL=

# Auth
JWT_SECRET=
AUTH_TOKEN_MAX_AGE=7d
ADMIN_TOKEN_VALUE=
ALLOW_LEGACY_ADMIN_TOKEN=false
SECURITY_ALLOWED_ORIGINS=https://k-lol-gg.vercel.app

# Kakao Bot/API
KAKAO_RECRUIT_SECRET=
KAKAO_SEARCH_PLAYER_SECRET=
KAKAO_OPENCHAT_SECRET=

# Riot
# Production 승인 전에는 false 유지. true로 바꾸면 서버 Route Handler에서만 Riot API 호출이 허용됩니다.
RIOT_FEATURE_ENABLED=false
RIOT_API_KEY=
RIOT_REGION=asia
RIOT_PLATFORM=kr
RIOT_MATCH_FETCH_LIMIT=20
RIOT_USER_SYNC_COOLDOWN_MINUTES=60
RIOT_ADMIN_SYNC_COOLDOWN_MINUTES=10
RIOT_ADMIN_FULL_SYNC_COOLDOWN_MINUTES=1440
RIOT_LOG_RETENTION_DAYS=90

# Security Phase 4
# Production에서는 false 권장. true면 Kakao secret을 query string에서도 임시 허용합니다.
SECURITY_ALLOW_QUERY_SECRET=false
# Kakao 서버 API까지 secret 검증을 강제하려면 true로 설정합니다.
SECURITY_REQUIRE_KAKAO_SECRET=false

# HMAC signature enforcement. Keep false during compatibility rollout, set true after bot/Kakao callers are updated.
SECURITY_REQUIRE_HMAC=false
# Riot Sign On / OAuth ownership verification
RIOT_RSO_ENABLED=false
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=
RIOT_RSO_STATE_TTL_MINUTES=10

# Site branding / premium defaults
NEXT_PUBLIC_SITE_NAME=K-LOL.GG
NEXT_PUBLIC_SITE_TAGLINE=내전 · 랭킹 · AI 데이터
NEXT_PUBLIC_ROOM_NAME=
NEXT_PUBLIC_SITE_LOGO_URL=
NEXT_PUBLIC_SITE_BACKGROUND_URL=
NEXT_PUBLIC_HOME_EYEBROW=KOREA LOL CUSTOM STATS
NEXT_PUBLIC_HOME_HERO_TITLE=실력을
NEXT_PUBLIC_HOME_HERO_ACCENT=증명하라
NEXT_PUBLIC_HOME_HERO_DESCRIPTION=내전 기록, 시즌 랭킹, 멸망전 진행과 MVP까지 한 화면에서 확인하세요. K-LOL.GG는 카카오톡 오픈채팅방 내전 운영을 위한 기록 허브입니다.
NEXT_PUBLIC_HOME_PRIMARY_CTA_LABEL=내전 보러가기
NEXT_PUBLIC_HOME_PRIMARY_CTA_HREF=/matches
NEXT_PUBLIC_HOME_SECONDARY_CTA_LABEL=플레이어 검색
NEXT_PUBLIC_HOME_SECONDARY_CTA_HREF=/players
NEXT_PUBLIC_KAKAO_OPENCHAT_URL=
NEXT_PUBLIC_USER_ASSISTANT_NAME=K-LOL 코치
NEXT_PUBLIC_ADMIN_ASSISTANT_NAME=AI 운영 비서
SITE_PREMIUM_ACCESS_DEFAULT=true
SITE_FEATURE_KAKAO_DEFAULT=true
SITE_FEATURE_RECRUIT_DEFAULT=true
SITE_FEATURE_BALANCE_AI_DEFAULT=true
SITE_FEATURE_RANDOM_TEAM_DEFAULT=false
SITE_FEATURE_RIOT_DEFAULT=false

# AI assistant
# 사이트 내부 운영 비서. 키가 없거나 일시적으로 사용할 수 없으면 기본 응답 모드로 동작합니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SITE_FEATURE_AI_ASSISTANT_DEFAULT=false
