generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Team {
  BLUE
  RED
}

enum Position {
  TOP
  JGL
  MID
  ADC
  SUP
}

enum EventMatchStatus {
  PLANNED
  RECRUITING
  TEAM_BUILDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventMatchMode {
  POSITION
  ARAM
}

enum EventTournamentStage {
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
}

enum DestructionStatus {
  PLANNED
  RECRUITING
  TEAM_BUILDING
  AUCTION
  PRELIMINARY
  TOURNAMENT
  COMPLETED
  CANCELLED
}

enum DestructionStage {
  PRELIMINARY
  SEMI_FINAL
  FINAL
}

enum DestructionMvpSelectionMethod {
  VOTE
  ADMIN
}

enum ApplyPosition {
  TOP
  JGL
  MID
  ADC
  SUP
  ALL
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ParticipationApplyStatus {
  APPLIED
  CONFIRMED
  REJECTED
  RESERVE
  CANCELLED
}

enum DestructionPreliminaryFormat {
  FULL_ROUND_ROBIN_BO3
  FULL_ROUND_ROBIN_BO1
  GROUP_ROUND_ROBIN_BO3
  GROUP_ROUND_ROBIN_BO1
  SWISS_ROUND_BO3
  SWISS_ROUND_BO1
  RANDOM_ROUNDS_BO3
  RANDOM_ROUNDS_BO1
}

enum DestructionAuctionStatus {
  PENDING
  DRAWN
  SOLD
  HOLD
  ASSIGNED
}

enum OperationAiRequestStatus {
  PENDING
  CONFIRMED
  REJECTED
  FAILED
}

model Player {
  id                    Int       @id @default(autoincrement())
  name                  String
  nickname              String
  tag                   String
  peakTier              String?
  currentTier           String?
  balanceOverrideScore  Float     @default(0)
  balanceOverrideReason String?
  isActive              Boolean   @default(true)
  deactivatedAt         DateTime?
  createdAt             DateTime  @default(now())

  userAccountId Int?         @unique
  userAccount   UserAccount? @relation(fields: [userAccountId], references: [id], onDelete: SetNull)

  participants  MatchParticipant[]
  seasonStats   PlayerSeasonStat[]
  championStats PlayerChampionStat[]
  positionStats PlayerPositionStat[]
  seasonResults SeasonResult[]

  seasonParticipationApplies      SeasonParticipationApply[]
  eventParticipationApplies       EventParticipationApply[]
  destructionParticipationApplies DestructionParticipationApply[]

  eventParticipants EventParticipant[]

  destructionCaptainTeams    DestructionTeam[]
  destructionParticipants    DestructionParticipant[]
  destructionMatchMvps       DestructionMatch[]                  @relation("DestructionMatchMvp")
  destructionMatchMvpVotes   DestructionMatchMvpVote[]           @relation("DestructionMatchVoteCandidate")
  destructionReplacementsOut DestructionParticipantReplacement[] @relation("DestructionReplacementOutgoingPlayer")
  destructionReplacementsIn  DestructionParticipantReplacement[] @relation("DestructionReplacementIncomingPlayer")
  teamBalanceDraftPlayers    TeamBalanceDraftPlayer[]

  riotAccount      PlayerRiotAccount?
  soloRankSnapshot PlayerSoloRankSnapshot?
  soloMatches      PlayerSoloMatch[]

  balanceProfile      PlayerBalanceProfile?
  balanceMatchResults PlayerBalanceMatchResult[]
  disciplineRecords   UserDisciplineRecord[]

  @@unique([nickname, tag])
  @@index([isActive, createdAt])
  @@index([name])
  @@index([nickname])
  @@index([tag])
}

model UserAccount {
  id                 Int        @id @default(autoincrement())
  userId             String     @unique
  passwordHash       String?
  adminTotpSecret    String?
  adminTotpEnabled   Boolean    @default(false)
  adminTotpEnabledAt DateTime?
  role               UserRole   @default(USER)
  status             UserStatus @default(PENDING)
  authVersion        Int        @default(0)

  discordId              String?   @unique
  discordUsername        String?
  discordGlobalName      String?
  discordServerNickname  String?
  discordAvatar          String?
  discordLinkedAt        DateTime?
  discordParsedBirthYear String?
  discordParsedName      String?
  discordParsedNickname  String?
  discordParsedTier      String?
  discordLinkStatus      String    @default("UNLINKED")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  player Player?

  discordVoiceEvents       DiscordVoiceEvent[]
  discordAccountLinkLogs   DiscordAccountLinkLog[]
  disciplineRecords        UserDisciplineRecord[]
  destructionMatchMvpVotes DestructionMatchMvpVote[]

  @@index([deletedAt])
}

model Champion {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  imageUrl  String
  createdAt DateTime @default(now())

  participants  MatchParticipant[]
  championStats PlayerChampionStat[]
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  matches                     MatchSeries[]
  seasonStats                 PlayerSeasonStat[]
  championStats               PlayerChampionStat[]
  positionStats               PlayerPositionStat[]
  seasonResults               SeasonResult[]
  participationApplies        SeasonParticipationApply[]
  pendingParticipationApplies SeasonParticipationPendingApply[]
  teamBalanceDrafts           TeamBalanceDraft[]
}

model MatchSeries {
  id                 Int      @id @default(autoincrement())
  title              String
  matchDate          DateTime
  seasonId           Int
  teamBalanceDraftId Int?
  createdAt          DateTime @default(now())

  season           Season            @relation(fields: [seasonId], references: [id])
  teamBalanceDraft TeamBalanceDraft? @relation(fields: [teamBalanceDraftId], references: [id], onDelete: SetNull)
  games            MatchGame[]

  balanceReviews      BalanceMatchReview[]
  balanceMatchResults PlayerBalanceMatchResult[]

  @@index([seasonId, matchDate])
  @@index([teamBalanceDraftId])
}

model MatchGame {
  id          Int    @id @default(autoincrement())
  seriesId    Int
  gameNumber  Int
  durationMin Int
  winnerTeam  Team
  mvpPlayerId Int?
  mvpScore    Float?

  series       MatchSeries        @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  participants MatchParticipant[]

  @@unique([seriesId, gameNumber])
  @@index([seriesId, gameNumber])
  @@index([mvpPlayerId])
}

model MatchParticipant {
  id         Int      @id @default(autoincrement())
  gameId     Int
  playerId   Int
  championId Int
  team       Team
  position   Position

  kills   Int
  deaths  Int
  assists Int

  game     MatchGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player   Player    @relation(fields: [playerId], references: [id])
  champion Champion  @relation(fields: [championId], references: [id])

  @@index([gameId])
  @@index([playerId])
  @@index([championId])
}

model PlayerSeasonStat {
  id       Int @id @default(autoincrement())
  playerId Int
  seasonId Int

  totalGames         Int
  participationCount Int @default(0)
  wins               Int
  losses             Int
  mvpCount           Int @default(0)

  player Player @relation(fields: [playerId], references: [id])
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId])
  @@index([seasonId, totalGames])
  @@index([seasonId, wins])
  @@index([seasonId, mvpCount])
  @@index([seasonId, participationCount])
  @@index([seasonId, totalGames, participationCount])
}

model PlayerChampionStat {
  id         Int @id @default(autoincrement())
  playerId   Int
  seasonId   Int
  championId Int

  games    Int
  wins     Int
  mvpCount Int @default(0)

  player   Player   @relation(fields: [playerId], references: [id])
  season   Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  champion Champion @relation(fields: [championId], references: [id])

  @@unique([playerId, seasonId, championId])
  @@index([seasonId])
  @@index([championId])
  @@index([playerId, seasonId, games])
}

model PlayerPositionStat {
  id       Int      @id @default(autoincrement())
  playerId Int
  seasonId Int
  position Position

  games Int
  wins  Int

  player Player @relation(fields: [playerId], references: [id])
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId, position])
  @@index([seasonId])
  @@index([playerId, seasonId, games])
}

model SeasonResult {
  id       Int    @id @default(autoincrement())
  seasonId Int
  category String
  playerId Int
  value    Float

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([seasonId, category, playerId])
  @@index([seasonId, category, value])
}

model RateLimitLog {
  id        Int      @id @default(autoincrement())
  key       String
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
}

model AdminLog {
  id          Int      @id @default(autoincrement())
  action      String
  message     String
  actorId     Int?
  actorType   String?
  actorUserId String?
  targetType  String?
  targetId    Int?
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Highlight {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  youtubeUrl   String
  youtubeId    String
  thumbnailUrl String?
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, sortOrder, createdAt])
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  imageUrl    String[]
  showOnHome  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventMatches           EventMatch[]
  destructionTournaments DestructionTournament[]

  @@index([showOnHome, createdAt])
}

model EventMatch {
  id          Int     @id @default(autoincrement())
  title       String
  description String? @db.Text

  status EventMatchStatus @default(RECRUITING)
  mode   EventMatchMode   @default(POSITION)

  eventDate   DateTime
  recruitFrom DateTime?
  recruitTo   DateTime?

  winnerTeamId   Int?
  mvpPlayerId    Int?
  galleryImageId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  galleryImage GalleryImage? @relation(fields: [galleryImageId], references: [id])

  teams                EventTeam[]
  participants         EventParticipant[]
  matches              EventTournamentMatch[]
  participationApplies EventParticipationApply[]

  @@index([status, eventDate])
  @@index([galleryImageId])
}

model EventTeam {
  id      Int    @id @default(autoincrement())
  eventId Int
  name    String
  seed    Int?
  score   Float  @default(0)

  event EventMatch @relation(fields: [eventId], references: [id], onDelete: Cascade)

  members EventParticipant[]

  matchesA EventTournamentMatch[] @relation("EventTeamA")
  matchesB EventTournamentMatch[] @relation("EventTeamB")

  @@unique([eventId, name])
  @@index([eventId, seed])
}

model EventParticipant {
  id       Int       @id @default(autoincrement())
  eventId  Int
  teamId   Int?
  playerId Int
  position Position?

  balanceScore Float @default(0)

  event  EventMatch @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team   EventTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player Player     @relation(fields: [playerId], references: [id])

  @@unique([eventId, playerId])
  @@index([eventId, teamId])
}

model EventTournamentMatch {
  id      Int                  @id @default(autoincrement())
  eventId Int
  stage   EventTournamentStage
  round   Int

  teamAId      Int
  teamBId      Int
  winnerTeamId Int?
  matchDate    DateTime?
  mvpPlayerId  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event EventMatch @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamA EventTeam  @relation("EventTeamA", fields: [teamAId], references: [id])
  teamB EventTeam  @relation("EventTeamB", fields: [teamBId], references: [id])

  @@unique([eventId, stage, round])
  @@index([eventId, winnerTeamId])
}

model DestructionTournament {
  id          Int               @id @default(autoincrement())
  title       String
  description String?           @db.Text
  status      DestructionStatus @default(RECRUITING)

  startDate DateTime?
  endDate   DateTime?

  preliminaryFormat     DestructionPreliminaryFormat @default(FULL_ROUND_ROBIN_BO3)
  preliminaryBestOf     Int                          @default(3)
  preliminaryRoundCount Int                          @default(3)
  advanceTeamCount      Int                          @default(4)

  topLaneLimit     Int @default(10)
  jungleLaneLimit  Int @default(10)
  midLaneLimit     Int @default(10)
  adcLaneLimit     Int @default(10)
  supportLaneLimit Int @default(10)

  winnerTeamId   Int?
  mvpPlayerId    Int?
  galleryImageId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  galleryImage GalleryImage? @relation(fields: [galleryImageId], references: [id])

  teams                   DestructionTeam[]
  participants            DestructionParticipant[]
  matches                 DestructionMatch[]
  participationApplies    DestructionParticipationApply[]
  scrimRecruits           DestructionScrimRecruit[]
  participantReplacements DestructionParticipantReplacement[]

  @@index([status, startDate])
  @@index([galleryImageId])
}

model DestructionTeam {
  id               Int     @id @default(autoincrement())
  tournamentId     Int
  name             String
  captainId        Int
  preliminaryGroup String?

  points Int @default(0)
  wins   Int @default(0)
  losses Int @default(0)

  initialAuctionPoints   Int @default(0)
  remainingAuctionPoints Int @default(0)

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  captain    Player                @relation(fields: [captainId], references: [id])

  members DestructionParticipant[]

  matchesA                DestructionMatch[]                  @relation("DestructionTeamA")
  matchesB                DestructionMatch[]                  @relation("DestructionTeamB")
  scrimRequesterRecruits  DestructionScrimRecruit[]           @relation("ScrimRequesterTeam")
  scrimOpponentRecruits   DestructionScrimRecruit[]           @relation("ScrimOpponentTeam")
  participantReplacements DestructionParticipantReplacement[]

  @@unique([tournamentId, name])
  @@index([tournamentId, points, wins, losses])
  @@index([tournamentId, preliminaryGroup])
}

model DestructionParticipant {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  teamId       Int?
  playerId     Int
  position     Position

  balanceScore  Float                    @default(0)
  isCaptain     Boolean                  @default(false)
  auctionStatus DestructionAuctionStatus @default(PENDING)
  purchasePoint Int?
  drawOrder     Int?
  soldAt        DateTime?

  tournament   DestructionTournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         DestructionTeam?                    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player       Player                              @relation(fields: [playerId], references: [id])
  replacements DestructionParticipantReplacement[]

  @@unique([tournamentId, playerId])
  @@index([tournamentId, teamId])
}

model DestructionParticipantReplacement {
  id               Int      @id @default(autoincrement())
  tournamentId     Int
  teamId           Int
  participantId    Int
  outgoingPlayerId Int
  incomingPlayerId Int
  outgoingPosition Position
  incomingPosition Position
  reason           String   @db.Text
  effectiveAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  tournament     DestructionTournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team           DestructionTeam        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  participant    DestructionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  outgoingPlayer Player                 @relation("DestructionReplacementOutgoingPlayer", fields: [outgoingPlayerId], references: [id])
  incomingPlayer Player                 @relation("DestructionReplacementIncomingPlayer", fields: [incomingPlayerId], references: [id])

  @@index([tournamentId, effectiveAt])
  @@index([participantId])
  @@index([outgoingPlayerId])
  @@index([incomingPlayerId])
}

model DestructionMatch {
  id               Int              @id @default(autoincrement())
  tournamentId     Int
  stage            DestructionStage
  round            Int
  preliminaryGroup String?

  teamAId               Int
  teamBId               Int
  winnerTeamId          Int?
  mvpPlayerId           Int?
  mvpSelectionMethod    DestructionMvpSelectionMethod?
  mvpFinalizedAt        DateTime?
  mvpVoteRound          Int                            @default(1)
  mvpRevoteCandidateIds Int[]                          @default([])

  isReplay    Boolean   @default(false)
  isConfirmed Boolean   @default(false)
  matchDate   DateTime?
  bestOf      Int       @default(1)
  teamAScore  Int       @default(0)
  teamBScore  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  teamA     DestructionTeam           @relation("DestructionTeamA", fields: [teamAId], references: [id])
  teamB     DestructionTeam           @relation("DestructionTeamB", fields: [teamBId], references: [id])
  mvpPlayer Player?                   @relation("DestructionMatchMvp", fields: [mvpPlayerId], references: [id], onDelete: SetNull)
  mvpVotes  DestructionMatchMvpVote[]

  @@unique([tournamentId, stage, round])
  @@index([tournamentId, winnerTeamId])
  @@index([tournamentId, stage, preliminaryGroup])
}

model DestructionMatchMvpVote {
  id                 Int      @id @default(autoincrement())
  matchId            Int
  voterUserAccountId Int
  candidatePlayerId  Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  match     DestructionMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voter     UserAccount      @relation(fields: [voterUserAccountId], references: [id], onDelete: Cascade)
  candidate Player           @relation("DestructionMatchVoteCandidate", fields: [candidatePlayerId], references: [id], onDelete: Cascade)

  @@unique([matchId, voterUserAccountId])
  @@index([matchId, candidatePlayerId])
  @@index([voterUserAccountId])
}

model SeasonParticipationApply {
  id        Int      @id @default(autoincrement())
  seasonId  Int
  playerId  Int
  applyDate DateTime
  recruitNo Int      @default(1)

  mainPosition ApplyPosition?
  subPositions ApplyPosition[]

  status ParticipationApplyStatus @default(APPLIED)

  source            String  @default("SITE")
  sourceRoom        String?
  sourceSender      String?
  sourceMessageHash String?
  sourceSlotNo      Int?
  applyTimeText     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, playerId, applyDate, recruitNo], map: "SeasonApply_recruitNo_unique")
  @@index([seasonId, applyDate, status])
  @@index([seasonId, applyDate, recruitNo, status], map: "SeasonApply_recruitNo_status_idx")
  @@index([seasonId, applyDate, source, status])
  @@index([sourceMessageHash])
}

model SeasonParticipationPendingApply {
  id        Int      @id @default(autoincrement())
  seasonId  Int
  applyDate DateTime
  recruitNo Int      @default(1)

  name        String
  currentTier String
  peakTier    String

  mainPosition ApplyPosition?
  subPositions ApplyPosition[]

  isReserve     Boolean @default(false)
  sourceSlotNo  Int?
  reserveSlotNo Int?

  reason String?

  source            String  @default("KAKAO_RECRUIT")
  sourceRoom        String?
  sourceSender      String?
  sourceMessageHash String?
  applyTimeText     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, applyDate, recruitNo, name, isReserve], map: "SeasonPending_recruitNo_unique")
  @@index([seasonId, applyDate, isReserve])
  @@index([seasonId, applyDate, recruitNo, isReserve], map: "SeasonPending_recruitNo_reserve_idx")
  @@index([seasonId, applyDate, source])
  @@index([sourceMessageHash])
}

model EventParticipationApply {
  id       Int @id @default(autoincrement())
  eventId  Int
  playerId Int

  mainPosition ApplyPosition?
  subPositions ApplyPosition[]

  status ParticipationApplyStatus @default(APPLIED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  EventMatch @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model DestructionParticipationApply {
  id           Int @id @default(autoincrement())
  tournamentId Int
  playerId     Int

  mainPosition ApplyPosition
  subPositions ApplyPosition[]

  isCaptain Boolean                  @default(false)
  status    ParticipationApplyStatus @default(APPLIED)
  message   String?                  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
}

model TeamBalanceDraft {
  id        Int      @id @default(autoincrement())
  title     String
  seasonId  Int?
  applyDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  optionType     String?
  formulaVersion String? @default("v3.0.0")
  isOfficial     Boolean @default(false)
  redTotal       Float?
  blueTotal      Float?
  diff           Float?
  balanceCost    Float?

  season         Season?                  @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  players        TeamBalanceDraftPlayer[]
  matchSeries    MatchSeries[]
  balanceReviews BalanceMatchReview[]

  @@index([createdAt])
  @@index([applyDate])
  @@index([isOfficial, createdAt])
}

model TeamBalanceDraftPlayer {
  id       Int @id @default(autoincrement())
  draftId  Int
  playerId Int

  team     Team
  position Position

  roleType      String?
  score         Float?
  baseScore     Float?
  soloBonus     Float?
  positionBonus Float?
  rolePenalty   Float?

  createdAt DateTime @default(now())

  draft  TeamBalanceDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([draftId, playerId])
}

model PlayerBalanceProfile {
  id       Int @id @default(autoincrement())
  playerId Int @unique

  overallMmr Float @default(50)
  topMmr     Float @default(50)
  jungleMmr  Float @default(50)
  midMmr     Float @default(50)
  adcMmr     Float @default(50)
  supportMmr Float @default(50)

  confidence      Float @default(0)
  matchesAnalyzed Int   @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastUpdatedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([overallMmr])
  @@index([confidence])
}

model BalanceMatchReview {
  id Int @id @default(autoincrement())

  matchSeriesId Int
  draftId       Int?

  selectedOptionType   String?
  predictedRedWinRate  Float?
  predictedBlueWinRate Float?
  actualWinner         Team?

  redTotal             Float?
  blueTotal            Float?
  diff                 Float?
  maxLineDiff          Float?
  midJglDiff           Float?
  bottomDiff           Float?
  autoCount            Int?
  highTierOffRoleCount Int?
  qualityScore         Float?

  aiVerdict        String?
  aiRiskLevel      String?
  aiConfidence     Float?
  aiInferredWinner Team?
  aiReasoning      String? @db.Text
  aiRiskFactors    String? @db.Text
  aiFormulaVersion String? @default("v2.0.0")

  feedbackRating      String?
  feedbackProblemTeam Team?
  feedbackProblemLine Position?
  feedbackMemo        String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchSeries MatchSeries       @relation(fields: [matchSeriesId], references: [id], onDelete: Cascade)
  draft       TeamBalanceDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([matchSeriesId])
  @@index([draftId])
  @@index([actualWinner])
}

model PlayerBalanceMatchResult {
  id Int @id @default(autoincrement())

  matchSeriesId Int
  gameId        Int?
  playerId      Int
  championId    Int?

  team     Team
  position Position
  kills    Int      @default(0)
  deaths   Int      @default(0)
  assists  Int      @default(0)
  win      Boolean  @default(false)

