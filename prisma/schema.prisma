generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Team {
  BLUE
  RED
}

enum Position {
  TOP
  JGL
  MID
  ADC
  SUP
}

enum EventMatchStatus {
  PLANNED
  RECRUITING
  TEAM_BUILDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventMatchMode {
  POSITION
  ARAM
}

enum EventTournamentStage {
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
}

enum DestructionStatus {
  PLANNED
  RECRUITING
  TEAM_BUILDING
  PRELIMINARY
  TOURNAMENT
  COMPLETED
  CANCELLED
}

enum DestructionStage {
  PRELIMINARY
  SEMI_FINAL
  FINAL
}

enum ApplyPosition {
  TOP
  JGL
  MID
  ADC
  SUP
  ALL
}

model Player {
  id          Int      @id @default(autoincrement())
  name        String
  nickname    String
  tag         String
  peakTier    String?
  currentTier String?
  createdAt   DateTime @default(now())

  // 🔽 추가 (핵심)
  userAccountId Int?         @unique
  userAccount   UserAccount? @relation(fields: [userAccountId], references: [id], onDelete: SetNull)

  participants  MatchParticipant[]
  seasonStats   PlayerSeasonStat[]
  championStats PlayerChampionStat[]
  positionStats PlayerPositionStat[]
  seasonResults SeasonResult[]

  seasonParticipationApplies      SeasonParticipationApply[]
  eventParticipationApplies       EventParticipationApply[]
  destructionParticipationApplies DestructionParticipationApply[]

  eventParticipants EventParticipant[]

  destructionCaptainTeams DestructionTeam[]
  destructionParticipants DestructionParticipant[]
  teamBalanceDraftPlayers TeamBalanceDraftPlayer[]

  @@unique([nickname, tag])
}

model UserAccount {
  id           Int        @id @default(autoincrement())
  userId       String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player Player?
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ParticipationApplyStatus {
  APPLIED
  CANCELLED
}

model Champion {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  imageUrl  String
  createdAt DateTime @default(now())

  participants  MatchParticipant[]
  championStats PlayerChampionStat[]
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  matches              MatchSeries[]
  seasonStats          PlayerSeasonStat[]
  seasonResults        SeasonResult[]
  participationApplies SeasonParticipationApply[]
  teamBalanceDrafts    TeamBalanceDraft[]
}

model MatchSeries {
  id        Int      @id @default(autoincrement())
  title     String
  matchDate DateTime
  seasonId  Int
  createdAt DateTime @default(now())

  season Season      @relation(fields: [seasonId], references: [id])
  games  MatchGame[]
}

model MatchGame {
  id          Int  @id @default(autoincrement())
  seriesId    Int
  gameNumber  Int
  durationMin Int
  winnerTeam  Team

  series       MatchSeries        @relation(fields: [seriesId], references: [id])
  participants MatchParticipant[]
}

model MatchParticipant {
  id         Int      @id @default(autoincrement())
  gameId     Int
  playerId   Int
  championId Int
  team       Team
  position   Position

  kills   Int
  deaths  Int
  assists Int

  game     MatchGame @relation(fields: [gameId], references: [id])
  player   Player    @relation(fields: [playerId], references: [id])
  champion Champion  @relation(fields: [championId], references: [id])
}

model PlayerSeasonStat {
  id       Int @id @default(autoincrement())
  playerId Int
  seasonId Int

  totalGames Int
  wins       Int
  losses     Int
  kda        Float
  avgGold    Float

  player Player @relation(fields: [playerId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])
}

model PlayerChampionStat {
  id         Int @id @default(autoincrement())
  playerId   Int
  championId Int

  games Int
  wins  Int
  kda   Float

  player   Player   @relation(fields: [playerId], references: [id])
  champion Champion @relation(fields: [championId], references: [id])
}

model PlayerPositionStat {
  id       Int      @id @default(autoincrement())
  playerId Int
  position Position

  games Int
  wins  Int

  player Player @relation(fields: [playerId], references: [id])
}

model SeasonResult {
  id       Int    @id @default(autoincrement())
  seasonId Int
  category String
  playerId Int
  value    Float

  season Season @relation(fields: [seasonId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  action    String
  message   String
  createdAt DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  imageUrl    String[]
  showOnHome  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventMatches           EventMatch[]
  destructionTournaments DestructionTournament[]
}

model EventMatch {
  id          Int     @id @default(autoincrement())
  title       String
  description String? @db.Text

  status EventMatchStatus @default(PLANNED)
  mode   EventMatchMode   @default(POSITION)

  eventDate   DateTime
  recruitFrom DateTime?
  recruitTo   DateTime?

  winnerTeamId   Int?
  mvpPlayerId    Int?
  galleryImageId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  galleryImage GalleryImage? @relation(fields: [galleryImageId], references: [id])

  teams                EventTeam[]
  participants         EventParticipant[]
  matches              EventTournamentMatch[]
  participationApplies EventParticipationApply[]
}

model EventTeam {
  id      Int    @id @default(autoincrement())
  eventId Int
  name    String
  seed    Int?
  score   Float  @default(0)

  event EventMatch @relation(fields: [eventId], references: [id])

  members EventParticipant[]

  matchesA EventTournamentMatch[] @relation("EventTeamA")
  matchesB EventTournamentMatch[] @relation("EventTeamB")
}

model EventParticipant {
  id       Int       @id @default(autoincrement())
  eventId  Int
  teamId   Int?
  playerId Int
  position Position?

  balanceScore Float @default(0)

  event  EventMatch @relation(fields: [eventId], references: [id])
  team   EventTeam? @relation(fields: [teamId], references: [id])
  player Player     @relation(fields: [playerId], references: [id])

  @@unique([eventId, playerId])
}

model EventTournamentMatch {
  id      Int                  @id @default(autoincrement())
  eventId Int
  stage   EventTournamentStage
  round   Int

  teamAId      Int
  teamBId      Int
  winnerTeamId Int?
  matchDate    DateTime?
  mvpPlayerId  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event EventMatch @relation(fields: [eventId], references: [id])
  teamA EventTeam  @relation("EventTeamA", fields: [teamAId], references: [id])
  teamB EventTeam  @relation("EventTeamB", fields: [teamBId], references: [id])
}

model DestructionTournament {
  id          Int               @id @default(autoincrement())
  title       String
  description String?           @db.Text
  status      DestructionStatus @default(PLANNED)

  startDate DateTime?
  endDate   DateTime?

  winnerTeamId   Int?
  mvpPlayerId    Int?
  galleryImageId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  galleryImage GalleryImage? @relation(fields: [galleryImageId], references: [id])

  teams                DestructionTeam[]
  participants         DestructionParticipant[]
  matches              DestructionMatch[]
  participationApplies DestructionParticipationApply[]
}

model DestructionTeam {
  id           Int    @id @default(autoincrement())
  tournamentId Int
  name         String
  captainId    Int

  points Int @default(0)
  wins   Int @default(0)
  losses Int @default(0)

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id])
  captain    Player                @relation(fields: [captainId], references: [id])

  members DestructionParticipant[]

  matchesA DestructionMatch[] @relation("DestructionTeamA")
  matchesB DestructionMatch[] @relation("DestructionTeamB")
}

model DestructionParticipant {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  teamId       Int?
  playerId     Int
  position     Position

  balanceScore Float @default(0)

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id])
  team       DestructionTeam?      @relation(fields: [teamId], references: [id])
  player     Player                @relation(fields: [playerId], references: [id])

  @@unique([tournamentId, playerId])
}

model DestructionMatch {
  id           Int              @id @default(autoincrement())
  tournamentId Int
  stage        DestructionStage
  round        Int

  teamAId      Int
  teamBId      Int
  winnerTeamId Int?
  mvpPlayerId  Int?

  isReplay  Boolean   @default(false)
  matchDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id])

  teamA DestructionTeam @relation("DestructionTeamA", fields: [teamAId], references: [id])
  teamB DestructionTeam @relation("DestructionTeamB", fields: [teamBId], references: [id])
}

model SeasonParticipationApply {
  id        Int      @id @default(autoincrement())
  seasonId  Int
  playerId  Int
  applyDate DateTime

  mainPosition ApplyPosition?
  subPositions ApplyPosition[]

  status ParticipationApplyStatus @default(APPLIED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, playerId, applyDate])
}

model EventParticipationApply {
  id       Int @id @default(autoincrement())
  eventId  Int
  playerId Int

  mainPosition ApplyPosition?
  subPositions ApplyPosition[]

  status ParticipationApplyStatus @default(APPLIED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  EventMatch @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model DestructionParticipationApply {
  id           Int @id @default(autoincrement())
  tournamentId Int
  playerId     Int

  mainPosition ApplyPosition
  subPositions ApplyPosition[]

  isCaptain Boolean                  @default(false)
  status    ParticipationApplyStatus @default(APPLIED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament DestructionTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
}

model TeamBalanceDraft {
  id        Int      @id @default(autoincrement())
  title     String
  seasonId  Int?
  applyDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season  Season?                  @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  players TeamBalanceDraftPlayer[]
}

model TeamBalanceDraftPlayer {
  id       Int @id @default(autoincrement())
  draftId  Int
  playerId Int

  team     Team
  position Position

  createdAt DateTime @default(now())

  draft  TeamBalanceDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([draftId, playerId])
}
