enum RecruitPartyType {
  FLEX_RANK
  NORMAL_GAME
  SOLO_RANK
  ARAM
  TFT_NORMAL
  TFT_RANK
  DOUBLE_UP
  PARTY_NUMBER
  PARTY_RIFT
  OTHER_GAME
}

enum RecruitPartyStatus {
  IN_PROGRESS
  FINISHED
  CANCELED
  RESET
}

model RecruitParty {
  id          Int                @id @default(autoincrement())
  recruitNo   Int
  recruitDate String
  resetSeq    Int                @default(0)
  recruitCode String?
  type        RecruitPartyType
  status      RecruitPartyStatus @default(IN_PROGRESS)

  title       String
  roomName    String?
  hostName    String?
  startTimeText     String?
  scheduledStartAt DateTime?
  tierText          String?
  preferredLineText String?
  playStyle         String?
  note              String?
  maxMembers Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members RecruitPartyMember[]
  discordMonitor RecruitPartyDiscordMonitor?

  @@unique([recruitDate, resetSeq, recruitNo])
  @@index([recruitCode])
  @@index([type])
  @@index([status, updatedAt])
  @@index([scheduledStartAt])
  @@index([recruitDate, resetSeq, status])
  @@index([createdAt])
}

model RecruitPartyMember {
  id        Int          @id @default(autoincrement())
  partyId   Int
  party     RecruitParty @relation(fields: [partyId], references: [id], onDelete: Cascade)

  name         String
  position     String?
  slotNo       Int?
  isSubstitute Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([partyId, position])
  @@unique([partyId, slotNo, isSubstitute])
  @@index([partyId])
}

model RecruitPartyLog {
  id          Int      @id @default(autoincrement())
  recruitNo   Int
  recruitDate String   @default("")
  resetSeq    Int      @default(0)
  type        String
  title       String
  action      String
  memberCount Int
  maxMembers  Int
  summary     String?  @db.Text
  roomName    String?
  sender      String?
  createdAt   DateTime @default(now())

  @@index([recruitDate, resetSeq, recruitNo])
  @@index([recruitDate, resetSeq, action, createdAt])
  @@index([recruitNo])
  @@index([action, createdAt])
  @@index([createdAt])
}



model DiscordVoiceEvent {
  id                Int      @id @default(autoincrement())
  discordId         String
  channelId         String?
  previousChannelId String?
  eventType         String
  occurredAt        DateTime @default(now())

  channelName           String?
